{
  "name": "dsp-server",
  "version": "1.0.0",
  "description": "Docker image vulnerability scanner API server",
  "main": "src/index.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node src/index.js",
    "dev": "nodemon src/index.js",
    "worker": "node src/workers/scanWorker.js",
    "build:client": "cd ../client && npm install && npm run build",
    "build": "npm run build:client",
    "prod": "npm run build && npm start"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "axios": "^1.6.2",
    "bull": "^4.12.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^3.0.2"
  }
}
